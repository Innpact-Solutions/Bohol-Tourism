# PostgreSQL connection string — Azure Database for PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=postgresql://gvxadmin:YOUR_PASSWORD@gvx-prod-db.postgres.database.azure.com:5432/philippines?sslmode=verify-full

# Server port (Azure App Service sets this automatically via PORT env var)
PORT=8080

# Set to "production" when deployed
NODE_ENV=development

# CORS allowed origins — comma-separated list or "*"
ALLOWED_ORIGIN=http://localhost:3000

# CORS allowed origin — set to your frontend URL in production
# e.g. https://ashy-coast-00baf9300.7.azurestaticapps.net
ALLOWED_ORIGIN=http://localhost:3000
